# Template de variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# Le fichier .env ne doit JAMAIS être commité (il est dans .gitignore)

# ─────────────────────────────────────────────
# GITHUB
# ─────────────────────────────────────────────
# Personal Access Token (github.com → Settings → Developer settings → Personal access tokens → Tokens (classic))
# Scopes nécessaires : repo, workflow
GITHUB_TOKEN=

# Nom d'utilisateur GitHub
GITHUB_USERNAME=

# Nom du dépôt GitHub
GITHUB_REPO=

# ─────────────────────────────────────────────
# NETLIFY
# ─────────────────────────────────────────────
# Personal Access Token (app.netlify.com → User settings → Applications → New access token)
NETLIFY_TOKEN=

# Site ID (disponible dans Netlify → Site settings → General → Site ID)
NETLIFY_SITE_ID=
